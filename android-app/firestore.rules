rules_version = '2';

// Deploy from the Firebase Console: Firestore Database -> Rules -> paste this in -> Publish.
// (Or with the CLI: firebase deploy --only firestore:rules, if you have a firebase.json wired up.)

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // One profile doc per user, id == their auth uid.
    // Only an admin may create one -- this is what actually grants access, so a self-registered
    // user must go through registrationRequests (below) and wait for admin approval rather than
    // ever being able to write their own role directly.
    match /profiles/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isAdmin();
      // Self-updates may never change role or email -- only an admin can do that --
      // otherwise a member could grant themselves admin via a direct SDK call.
      allow update: if isAdmin() || (
        isSelf(uid) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.email == resource.data.email
      );
      allow delete: if isAdmin();
    }

    // A self-registered user (via Google or email/password on the website) lands here with
    // status "pending" until an admin reviews and approves them, at which point the admin
    // creates the matching profiles/{uid} document with a role and removes this request.
    match /registrationRequests/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.fullName is string &&
        request.resource.data.email is string;
      allow update, delete: if isAdmin();
    }

    // Incoming donations -- admin-only in both directions, members never see donor detail.
    match /donations/{id} {
      allow read, write: if isAdmin();
    }

    // Direct org-level expenses -- admin-only in both directions.
    match /orgExpenses/{id} {
      allow read, write: if isAdmin();
    }

    // Admin allots a fund/scholarship to a member; that member can read only their own rows.
    match /memberAllocations/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow write: if isAdmin();
    }

    // A member logs their own spending; admin can read everything for oversight.
    match /memberExpenses/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
    }

    function isValidPostBody() {
      return request.resource.data.body is string &&
        request.resource.data.body.size() > 0 &&
        request.resource.data.body.size() <= 500;
    }

    // authorRole is denormalized onto every post/comment so the UI can show a role badge
    // without an extra read -- must match the poster's real profile role or it'd let anyone
    // forge an "admin" badge on their own post.
    function isValidAuthorRole() {
      return request.resource.data.authorRole == getRole();
    }

    // Community feed (Vidvat Panchayat) -- any signed-in profile can read every post and post
    // as themselves. Text only, capped at 500 characters; no edit once posted. A non-admin may
    // only ever nudge commentCount up by exactly 1 (when they add a comment); an admin can
    // delete any post to moderate the discussion.
    match /communityPosts/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.commentCount == 0 &&
        isValidPostBody() && isValidAuthorRole();
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']) &&
        request.resource.data.commentCount == resource.data.commentCount + 1
      );
      allow delete: if isAdmin();
    }

    // Comments on a community post -- same rules as posts, scoped by postId. An admin can
    // delete any comment to moderate the discussion.
    match /communityComments/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        isValidPostBody() && isValidAuthorRole();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Single document holding org-wide totals (donations - org expenses - allotments).
    // Kept in sync by the admin client via batched increment() writes alongside each ledger
    // entry -- there's no Cloud Function maintaining it, so only admin may write it. Every
    // signed-in role may read the totals except scholar, who only sees their own allotment.
    match /orgSummary/{docId} {
      allow read: if isSignedIn() && getRole() != 'scholar';
      allow write: if isAdmin();
    }

    // One per-member summary doc (allotted / spent / remaining), id == member's uid.
    // Admin can write anything on it (e.g. when allotting funds); a member may only nudge
    // their own totalSpent/remainingBalance when logging an expense, never totalAllotted.
    match /memberSummaries/{memberId} {
      allow read: if isAdmin() || isSelf(memberId);
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isSelf(memberId) && request.resource.data.totalAllotted == resource.data.totalAllotted);
      allow delete: if isAdmin();
    }
  }
}
