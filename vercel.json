{
  "installCommand": "cd website && npm install",
  "buildCommand": "cd website && npm run build",
  "outputDirectory": "website/dist",
  "rewrites": [
    {
      "source": "/about",
      "destination": "/"
    },
    {
      "source": "/work",
      "destination": "/"
    },
    {
      "source": "/research",
      "destination": "/"
    },
    {
      "source": "/contact",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ]
}
